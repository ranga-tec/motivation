@{
    ViewData["Title"] = "Reports";
}

<div class="page-header">
    <h1 class="page-title">Reports</h1>
    <p class="page-subtitle">Generate and export system reports</p>
</div>

<div class="row g-4">
    <div class="col-md-6 col-lg-4">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div class="kpi-icon kpi-primary me-3" style="width: 48px; height: 48px; border-radius: 10px; display: flex; align-items: center; justify-content: center; background-color: rgba(37, 99, 235, 0.15); color: #2563eb;">
                        <i class="fas fa-user-plus"></i>
                    </div>
                    <h5 class="mb-0">Patient Registration</h5>
                </div>
                <p class="text-muted mb-3">Report of patients registered within a date range, with center filter.</p>
                <a asp-action="PatientRegistration" class="btn btn-outline-primary">
                    <i class="fas fa-file-alt me-2"></i>Generate Report
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-4">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div class="kpi-icon kpi-success me-3" style="width: 48px; height: 48px; border-radius: 10px; display: flex; align-items: center; justify-content: center; background-color: rgba(5, 150, 105, 0.15); color: #059669;">
                        <i class="fas fa-users"></i>
                    </div>
                    <h5 class="mb-0">Patient List</h5>
                </div>
                <p class="text-muted mb-3">Complete list of patients with active/inactive status filter.</p>
                <a asp-action="PatientList" class="btn btn-outline-success">
                    <i class="fas fa-file-alt me-2"></i>Generate Report
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-4">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div class="kpi-icon kpi-info me-3" style="width: 48px; height: 48px; border-radius: 10px; display: flex; align-items: center; justify-content: center; background-color: rgba(2, 132, 199, 0.15); color: #0284c7;">
                        <i class="fas fa-folder-open"></i>
                    </div>
                    <h5 class="mb-0">Episode Summary</h5>
                </div>
                <p class="text-muted mb-3">Episodes opened within a date range, filter by type.</p>
                <a asp-action="Episodes" class="btn btn-outline-info">
                    <i class="fas fa-file-alt me-2"></i>Generate Report
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-4">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div class="kpi-icon kpi-warning me-3" style="width: 48px; height: 48px; border-radius: 10px; display: flex; align-items: center; justify-content: center; background-color: rgba(217, 119, 6, 0.15); color: #d97706;">
                        <i class="fas fa-truck"></i>
                    </div>
                    <h5 class="mb-0">Deliveries</h5>
                </div>
                <p class="text-muted mb-3">Device deliveries within a date range, with center filter.</p>
                <a asp-action="Deliveries" class="btn btn-outline-warning">
                    <i class="fas fa-file-alt me-2"></i>Generate Report
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-4">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex align-items-center mb-3">
                    <div class="kpi-icon kpi-danger me-3" style="width: 48px; height: 48px; border-radius: 10px; display: flex; align-items: center; justify-content: center; background-color: rgba(220, 38, 38, 0.15); color: #dc2626;">
                        <i class="fas fa-calendar-check"></i>
                    </div>
                    <h5 class="mb-0">Follow-ups</h5>
                </div>
                <p class="text-muted mb-3">Follow-up appointments within a date range.</p>
                <a asp-action="FollowUps" class="btn btn-outline-danger">
                    <i class="fas fa-file-alt me-2"></i>Generate Report
                </a>
            </div>
        </div>
    </div>
</div>
