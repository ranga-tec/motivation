@model List<DocumentListItem>
@using Poms.Domain.Enums
@{
    ViewData["Title"] = "Documents";
}

<div class="page-header">
    <h1 class="page-title">Documents</h1>
    <p class="page-subtitle">Manage patient and episode documents</p>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-header">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Search</label>
                <input type="text" class="form-control" name="searchString" value="@ViewBag.SearchString"
                       placeholder="Title, filename, patient number...">
            </div>
            <div class="col-md-3">
                <label class="form-label">OCR Status</label>
                <select name="ocrStatus" class="form-select">
                    <option value="">All</option>
                    @foreach (var status in ViewBag.OcrStatuses)
                    {
                        <option value="@status" selected="@(ViewBag.OcrStatus?.ToString() == status.ToString())">@status</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-search me-1"></i> Search
                </button>
            </div>
        </form>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Patient</th>
                        <th>Type</th>
                        <th>Content Type</th>
                        <th>Uploaded</th>
                        <th>OCR Status</th>
                        <th width="120">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var doc in Model)
                    {
                        <tr>
                            <td>
                                <i class="fas fa-@(doc.ContentType.StartsWith("image/") ? "image" :
                                    doc.ContentType == "application/pdf" ? "file-pdf" : "file") me-2 text-muted"></i>
                                @doc.Title
                            </td>
                            <td>
                                <strong>@doc.PatientNumber</strong><br>
                                <small class="text-muted">@doc.PatientName</small>
                            </td>
                            <td><span class="badge bg-secondary">@doc.DocumentType</span></td>
                            <td><small>@doc.ContentType</small></td>
                            <td>@doc.UploadedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                <span class="badge bg-@(doc.OcrStatus == OcrStatus.Completed ? "success" :
                                    doc.OcrStatus == OcrStatus.Processing ? "warning" :
                                    doc.OcrStatus == OcrStatus.Pending ? "info" :
                                    doc.OcrStatus == OcrStatus.Failed ? "danger" : "secondary")">
                                    @doc.OcrStatus
                                </span>
                            </td>
                            <td>
                                @if (doc.DocumentType == "Patient")
                                {
                                    <a asp-action="ViewPatientDocument" asp-route-id="@doc.Id"
                                       class="btn btn-sm btn-outline-primary" target="_blank">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="PatientDocumentDetails" asp-route-id="@doc.Id"
                                       class="btn btn-sm btn-outline-info">
                                        <i class="fas fa-info-circle"></i>
                                    </a>
                                }
                                else
                                {
                                    <a asp-action="ViewEpisodeDocument" asp-route-id="@doc.Id"
                                       class="btn btn-sm btn-outline-primary" target="_blank">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="EpisodeDocumentDetails" asp-route-id="@doc.Id"
                                       class="btn btn-sm btn-outline-info">
                                        <i class="fas fa-info-circle"></i>
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-3">No documents found</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (ViewBag.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i"
                       asp-route-searchString="@ViewBag.SearchString"
                       asp-route-ocrStatus="@ViewBag.OcrStatus">@i</a>
                </li>
            }
        </ul>
    </nav>
}
