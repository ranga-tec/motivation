@model DocumentDetailsViewModel
@using Poms.Domain.Enums
@{
    ViewData["Title"] = "Document Details";
}

<div class="page-header">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Documents</a></li>
            <li class="breadcrumb-item active">Details</li>
        </ol>
    </nav>
    <h1 class="page-title">@Model.Title</h1>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Document Information</h5>
                @if (Model.DocumentType == "Patient")
                {
                    <a asp-action="ViewPatientDocument" asp-route-id="@Model.Id" target="_blank"
                       class="btn btn-sm btn-outline-primary">
                        <i class="fas fa-external-link-alt me-1"></i>Open
                    </a>
                }
                else
                {
                    <a asp-action="ViewEpisodeDocument" asp-route-id="@Model.Id" target="_blank"
                       class="btn btn-sm btn-outline-primary">
                        <i class="fas fa-external-link-alt me-1"></i>Open
                    </a>
                }
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="text-muted small">File Name</label>
                        <div class="fw-semibold">@Model.FileName</div>
                    </div>
                    <div class="col-md-3">
                        <label class="text-muted small">File Size</label>
                        <div class="fw-semibold">@Model.FileSizeFormatted</div>
                    </div>
                    <div class="col-md-3">
                        <label class="text-muted small">Content Type</label>
                        <div class="fw-semibold">@Model.ContentType</div>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="text-muted small">Uploaded By</label>
                        <div class="fw-semibold">@Model.UploadedBy</div>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted small">Uploaded At</label>
                        <div class="fw-semibold">@Model.UploadedAt.ToString("yyyy-MM-dd HH:mm:ss")</div>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(Model.Remarks))
                {
                    <div class="mb-3">
                        <label class="text-muted small">Remarks</label>
                        <div class="border rounded p-2 bg-light">@Model.Remarks</div>
                    </div>
                }
            </div>
        </div>

        <!-- OCR Section -->
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fas fa-file-alt me-2"></i>OCR Extracted Text
                </h5>
                <span class="badge bg-@(Model.OcrStatus == OcrStatus.Completed ? "success" :
                    Model.OcrStatus == OcrStatus.Processing ? "warning" :
                    Model.OcrStatus == OcrStatus.Pending ? "info" :
                    Model.OcrStatus == OcrStatus.Failed ? "danger" : "secondary")">
                    @Model.OcrStatus
                </span>
            </div>
            <div class="card-body">
                @if (Model.OcrStatus == OcrStatus.Completed && !string.IsNullOrEmpty(Model.ExtractedText))
                {
                    <div class="mb-3">
                        <small class="text-muted">
                            Language: @(Model.OcrLanguage ?? "Unknown") |
                            Processed: @(Model.OcrProcessedAt?.ToString("yyyy-MM-dd HH:mm") ?? "-")
                        </small>
                    </div>
                    <div class="border rounded p-3 bg-light" style="max-height: 400px; overflow-y: auto; white-space: pre-wrap;">
                        @Model.ExtractedText
                    </div>
                }
                else if (Model.OcrStatus == OcrStatus.NotApplicable)
                {
                    <div class="text-muted text-center py-3">
                        <i class="fas fa-info-circle me-2"></i>OCR is not applicable for this file type
                    </div>
                }
                else if (Model.OcrStatus == OcrStatus.Pending || Model.OcrStatus == OcrStatus.Processing)
                {
                    <div class="text-center py-3">
                        <i class="fas fa-spinner fa-spin me-2"></i>OCR processing...
                    </div>
                }
                else if (Model.OcrStatus == OcrStatus.Failed)
                {
                    <div class="text-danger text-center py-3">
                        <i class="fas fa-exclamation-circle me-2"></i>OCR processing failed
                    </div>
                }
                else
                {
                    <div class="text-muted text-center py-3">No extracted text available</div>
                }

                @if (Model.OcrStatus != OcrStatus.NotApplicable)
                {
                    <div class="mt-3">
                        <form asp-action="ReprocessOcr" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <input type="hidden" name="documentType" value="@Model.DocumentType" />
                            <div class="input-group">
                                <select name="language" class="form-select" style="max-width: 150px;">
                                    <option value="eng">English</option>
                                    <option value="sin">Sinhala</option>
                                    <option value="tam">Tamil</option>
                                </select>
                                <button type="submit" class="btn btn-outline-primary">
                                    <i class="fas fa-redo me-2"></i>Re-process OCR
                                </button>
                            </div>
                        </form>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Related Information</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="text-muted small">Document Type</label>
                    <div><span class="badge bg-secondary">@Model.DocumentType</span></div>
                </div>
                <div class="mb-3">
                    <label class="text-muted small">Patient Number</label>
                    <div class="fw-semibold">@Model.PatientNumber</div>
                </div>
                <div class="mb-3">
                    <label class="text-muted small">Patient Name</label>
                    <div class="fw-semibold">@Model.PatientName</div>
                </div>
                @if (Model.DocumentType == "Patient")
                {
                    <a asp-controller="Patients" asp-action="Details" asp-route-id="@Model.ParentId"
                       class="btn btn-outline-primary w-100">
                        <i class="fas fa-user me-2"></i>View Patient
                    </a>
                }
                else
                {
                    <a asp-controller="Episodes" asp-action="Details" asp-route-id="@Model.ParentId"
                       class="btn btn-outline-primary w-100">
                        <i class="fas fa-folder-open me-2"></i>View Episode
                    </a>
                }
            </div>
        </div>
    </div>
</div>
