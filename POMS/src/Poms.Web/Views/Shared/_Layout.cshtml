<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - POMS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/poms-theme.css" asp-append-version="true" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light navbar-poms">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-wheelchair me-2"></i><strong>POMS</strong>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
                               asp-controller="Home" asp-action="Index">
                                <i class="fas fa-tachometer-alt me-1"></i> Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Patients" ? "active" : "")"
                               asp-controller="Patients" asp-action="Index">
                                <i class="fas fa-users me-1"></i> Patients
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Episodes" ? "active" : "")"
                               asp-controller="Episodes" asp-action="Index">
                                <i class="fas fa-folder-open me-1"></i> Episodes
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="clinicalDropdown" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="fas fa-stethoscope me-1"></i> Clinical
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="clinicalDropdown">
                                <li><a class="dropdown-item" asp-controller="Fittings" asp-action="Index">
                                    <i class="fas fa-cogs me-2"></i>Fittings</a></li>
                                <li><a class="dropdown-item" asp-controller="Conditions" asp-action="Index">
                                    <i class="fas fa-heartbeat me-2"></i>Conditions</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-controller="Documents" asp-action="Index">
                                    <i class="fas fa-file-medical me-2"></i>Documents</a></li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reports" ? "active" : "")"
                               asp-controller="Reports" asp-action="Index">
                                <i class="fas fa-chart-bar me-1"></i> Reports
                            </a>
                        </li>
                        @if (User.IsInRole("ADMIN"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle @(ViewContext.RouteData.Values["controller"]?.ToString()?.StartsWith("Admin") == true ||
                                    ViewContext.RouteData.Values["controller"]?.ToString() == "Users" ? "active" : "")"
                                   href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="fas fa-cog me-1"></i> Admin
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="adminDropdown">
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Index">
                                        <i class="fas fa-tachometer-alt me-2"></i>Admin Dashboard</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-controller="Users" asp-action="Index">
                                        <i class="fas fa-users-cog me-2"></i>User Management</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li class="dropdown-header">Master Data</li>
                                    <li><a class="dropdown-item" asp-controller="Provinces" asp-action="Index">
                                        <i class="fas fa-map me-2"></i>Provinces</a></li>
                                    <li><a class="dropdown-item" asp-controller="Districts" asp-action="Index">
                                        <i class="fas fa-map-marker-alt me-2"></i>Districts</a></li>
                                    <li><a class="dropdown-item" asp-controller="Centers" asp-action="Index">
                                        <i class="fas fa-hospital me-2"></i>Centers</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-controller="DeviceTypes" asp-action="Index">
                                        <i class="fas fa-cubes me-2"></i>Device Types</a></li>
                                    <li><a class="dropdown-item" asp-controller="DeviceCatalog" asp-action="Index">
                                        <i class="fas fa-list me-2"></i>Device Catalog</a></li>
                                    <li><a class="dropdown-item" asp-controller="ComponentCatalog" asp-action="Index">
                                        <i class="fas fa-puzzle-piece me-2"></i>Components</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Settings">
                                        <i class="fas fa-sliders-h me-2"></i>Settings</a></li>
                                </ul>
                            </li>
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <!-- Version Switcher Banner -->
    <div style="background:#1d4ed8;color:#fff;text-align:center;padding:8px 16px;font-size:14px;font-weight:600;display:flex;align-items:center;justify-content:center;gap:16px;">
        <span>&#10024; You are viewing the <strong>PRODUCTION</strong> version</span>
        <a href="/Switch/Go?target=prototype"
           style="background:#fff;color:#1d4ed8;padding:4px 14px;border-radius:4px;text-decoration:none;font-weight:700;font-size:13px;">
            &larr; Switch to Prototype Version
        </a>
    </div>

    <div class="container-fluid py-3">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted py-3">
        <div class="container text-center">
            <small>&copy; @DateTime.Now.Year POMS - Prosthetic, Orthotic & Spinal Patient Management System</small>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
