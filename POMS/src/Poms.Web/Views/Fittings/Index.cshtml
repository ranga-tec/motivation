@model List<Poms.Domain.Entities.Fitting>
@using Poms.Domain.Enums
@{
    ViewData["Title"] = "Fittings";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title">Fittings</h1>
        <p class="page-subtitle">Manage device fitting sessions</p>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-header">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Status</label>
                <select name="status" class="form-select">
                    <option value="">All Statuses</option>
                    @foreach (var status in Enum.GetValues<FittingStatus>())
                    {
                        <option value="@status" selected="@(ViewBag.Status?.ToString() == status.ToString())">@status</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-search me-1"></i> Filter
                </button>
            </div>
        </form>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Patient</th>
                        <th>Fitting #</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th>Performed By</th>
                        <th>Next Fitting</th>
                        <th width="100">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var fitting in Model)
                    {
                        <tr class="table-clickable" onclick="window.location='@Url.Action("Details", new { id = fitting.Id })'">
                            <td>
                                <strong>@fitting.Episode.Patient.PatientNumber</strong><br>
                                <small>@fitting.Episode.Patient.FirstName @fitting.Episode.Patient.LastName</small>
                            </td>
                            <td>
                                <span class="fitting-number">@fitting.FittingNumber</span>
                            </td>
                            <td>@fitting.FittingDate.ToString("yyyy-MM-dd")</td>
                            <td>
                                <span class="badge bg-@(fitting.Status == FittingStatus.Completed ? "success" :
                                    fitting.Status == FittingStatus.InProgress ? "warning" :
                                    fitting.Status == FittingStatus.Scheduled ? "info" : "secondary")">
                                    @fitting.Status
                                </span>
                            </td>
                            <td>@(fitting.PerformedBy ?? "-")</td>
                            <td>@(fitting.NextFittingDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                            <td onclick="event.stopPropagation()">
                                <a asp-action="Edit" asp-route-id="@fitting.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-edit"></i>
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-3">No fittings found</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (ViewBag.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i"
                       asp-route-status="@ViewBag.Status">@i</a>
                </li>
            }
        </ul>
    </nav>
}
